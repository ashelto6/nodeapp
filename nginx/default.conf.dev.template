server {
    listen ${NGINX_PORT};
    server_name ${NGINX_HOST};

    location /api/ {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_pass http://${SERVER_HOST}:${SERVER_PORT};
        proxy_http_version 1.1;
    }

    # Security headers (issue #115) are deliberately NOT added here: this
    # proxies to Vite's dev server, whose HMR websocket and inline dev
    # tooling would conflict with a locked-down CSP. Headers apply to the
    # prod template only, where nginx serves the built static output.
    location / {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_pass http://${CLIENT_HOST}:${CLIENT_PORT};
        proxy_http_version 1.1;
    }
}
