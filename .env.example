# GHCR namespace docker-compose.yaml pulls images from -- keeps the repo
# owner out of docker-compose.yaml itself so a fork/transfer/rename only
# needs this value updated, not the compose file (issue #16).
# docker-compose.yaml falls back to `ashelto6` (${IMAGE_OWNER:-ashelto6}) if
# this is unset -- an existing server's .env (gitignored, so this feature's
# introduction doesn't retroactively populate it) still deploys correctly
# without manual intervention; set it explicitly only for a fork/transfer.
# IMAGE_TAG is deliberately not set here: it defaults to `latest` via
# docker-compose.yaml's ${IMAGE_TAG:-latest}, and deploy.yml exports the
# real value (the deploying commit's SHA) as a shell env var rather than
# writing it to a file.
IMAGE_OWNER=ashelto6

SERVER_PORT=8888
SERVER_HOST=node-c
NGINX_PORT=9999
NGINX_HOST=nginx-c

MONGO_HOST=mongo-c
MONGO_PORT=27017
MONGO_DB=nodeapp
# Root credentials: used only by Mongo itself (container init / admin tasks),
# never by the app. Keep these distinct from the app credentials below.
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=changeme
# App credentials: what server/src/db.js actually connects with -- scoped to
# readWrite on MONGO_DB only (see mongo/init/create-app-user.js). Must be a
# different password than root's, especially in production.
MONGO_APP_USERNAME=nodeapp_app
MONGO_APP_PASSWORD=changeme_too

CLIENT_HOST=client-c
CLIENT_PORT=5173

LOG_LEVEL=info

# Optional: Sentry error tracking DSN. Blank/absent = Sentry disabled
# (correct for tests/CI/local dev). Set the real DSN in production .env.
SENTRY_DSN=
