SERVER_PORT=8888
SERVER_HOST=node-c
NGINX_PORT=9999
NGINX_HOST=nginx-c

MONGO_HOST=mongo-c
MONGO_PORT=27017
MONGO_DB=nodeapp
# Root credentials: used only by Mongo itself (container init / admin tasks),
# never by the app. Keep these distinct from the app credentials below.
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=changeme
# App credentials: what server/src/db.js actually connects with -- scoped to
# readWrite on MONGO_DB only (see mongo/init/create-app-user.js). Must be a
# different password than root's, especially in production.
MONGO_APP_USERNAME=nodeapp_app
MONGO_APP_PASSWORD=changeme_too

CLIENT_HOST=client-c
CLIENT_PORT=5173

LOG_LEVEL=info

# Optional: Sentry error tracking DSN. Blank/absent = Sentry disabled
# (correct for tests/CI/local dev). Set the real DSN in production .env.
SENTRY_DSN=
